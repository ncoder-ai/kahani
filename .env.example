# ============================================================================
# KAHANI ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit .env to git - it contains secrets!
# ============================================================================

# ----------------------------------------------------------------------------
# SECURITY - REQUIRED
# Generate secure random strings for these values
# ----------------------------------------------------------------------------

# Secret key for general application security
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here

# JWT secret key for authentication tokens
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-jwt-secret-key-here

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ----------------------------------------------------------------------------
# 
# OPTION 1: SQLite (Default - No setup needed)
#   - Leave DATABASE_URL unset or set to:
#   DATABASE_URL=sqlite:///./data/kahani.db
#   - Works out of the box, no additional configuration
#
# OPTION 2: PostgreSQL (Recommended for production)
#   To use PostgreSQL with Docker Compose:
#   1. Uncomment the postgres service in docker-compose.yml
#   2. Uncomment the depends_on section in backend service in docker-compose.yml
#   3. Uncomment the volumes section at the bottom of docker-compose.yml
#   4. Uncomment and set these variables below:
#
# POSTGRES_USER=kahani
# POSTGRES_PASSWORD=your_secure_password_here
# POSTGRES_DB=kahani
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
#
# For local/baremetal PostgreSQL (not Docker):
# DATABASE_URL=postgresql://user:password@localhost:5432/kahani

# Default: SQLite (uncomment to override)
# DATABASE_URL=sqlite:///./data/kahani.db

# PostgreSQL (uncomment and configure if using PostgreSQL)
# POSTGRES_USER=kahani
# POSTGRES_PASSWORD=your_secure_password_here
# POSTGRES_DB=kahani
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ----------------------------------------------------------------------------
# NEXT_PUBLIC_API_URL - Frontend to Backend Communication
# ----------------------------------------------------------------------------
# Tells the Next.js frontend where to find the backend API
# 
# WHEN TO SET:
# - Docker deployments: REQUIRED (containers can't use localhost)
# - Baremetal (same machine): OPTIONAL (auto-detects, but can override)
# - Separate machines: REQUIRED (frontend needs backend's address)
#
# EXAMPLES:
# Local development (auto-set by start-dev.sh):
# NEXT_PUBLIC_API_URL=http://localhost:9876
#
# Docker (use service name):
# NEXT_PUBLIC_API_URL=http://backend:9876
#
# Intranet access (both services on same server):
# NEXT_PUBLIC_API_URL=http://192.168.1.100:9876
#
# Reverse proxy (both services on same server):
# NEXT_PUBLIC_API_URL=http://localhost:9876
# OR
# NEXT_PUBLIC_API_URL=https://yourdomain.com
#
# Uncomment and set based on your deployment:
# NEXT_PUBLIC_API_URL=http://localhost:9876

# ----------------------------------------------------------------------------
# CORS CONFIGURATION
# ----------------------------------------------------------------------------
# Comma-separated list of allowed origins, or ["*"] for all
# Example: ["http://localhost:6789", "https://yourdomain.com"]
# Default: * (allows all origins)
# CORS_ORIGINS=["http://localhost:6789"]
