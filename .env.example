# ============================================================================
# KAHANI ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ============================================================================

# ----------------------------------------------------------------------------
# SECURITY - REQUIRED
# Generate secure random strings for these values
# ----------------------------------------------------------------------------

# Secret key for general application security
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here

# JWT secret key for authentication tokens
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-jwt-secret-key-here

# ----------------------------------------------------------------------------
# NEXT_PUBLIC_API_URL - Frontend to Backend Communication
# ----------------------------------------------------------------------------
# Tells the Next.js frontend where to find the backend API
# 
# WHEN TO SET:
# - Docker deployments: REQUIRED (containers can't use localhost)
# - Baremetal (same machine): OPTIONAL (auto-detects, but can override)
# - Separate machines: REQUIRED (frontend needs backend's address)
#
# EXAMPLES:
# Local development (auto-set by start-dev.sh):
# NEXT_PUBLIC_API_URL=http://localhost:9876
#
# Docker (use service name):
# NEXT_PUBLIC_API_URL=http://backend:9876
#
# Intranet access (both services on same server):
# NEXT_PUBLIC_API_URL=http://192.168.1.100:9876
#
# Reverse proxy (both services on same server):
# NEXT_PUBLIC_API_URL=http://localhost:9876
# OR
# NEXT_PUBLIC_API_URL=https://yourdomain.com
#
# Uncomment and set based on your deployment:
# NEXT_PUBLIC_API_URL=http://localhost:9876

# ----------------------------------------------------------------------------
# OPTIONAL OVERRIDES
# Uncomment and modify these to override config.yaml defaults
# ----------------------------------------------------------------------------

# Database URL (default: sqlite:///./data/kahani.db from config.yaml)
# DATABASE_URL=sqlite:///./data/kahani.db
# DATABASE_URL=postgresql://user:password@localhost:5432/kahani

# CORS Origins (default: * from config.yaml)
# CORS_ORIGINS=*
# CORS_ORIGINS=["http://localhost:6789","http://192.168.1.100:6789"]
